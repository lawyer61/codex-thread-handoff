{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" session-start",
            "statusMessage": "Loading thread handoff"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" user-prompt-submit",
            "statusMessage": "Checking relevant thread memory"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" post-tool-use",
            "statusMessage": "Recording tool result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" stop",
            "statusMessage": "Updating thread handoff"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" pre-compact",
            "statusMessage": "Checking handoff freshness"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/bin/thread-handoff.js\" post-compact",
            "statusMessage": "Marking new context epoch"
          }
        ]
      }
    ]
  }
}
